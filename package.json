{
  "name": "paye-oft-solana",
  "version": "0.1.0",
  "private": true,
  "description": "PAYE (PayETH) — LayerZero OFT v2 Solana remote-chain deployment",
  "scripts": {
    "build:anchor": "anchor build -e OFT_ID=$(anchor keys list | awk '/paye[_-]oft/{print $2}')",
    "build:anchor:verifiable": "anchor build -v -e OFT_ID=$(anchor keys list | awk '/paye[_-]oft/{print $2}')",
    "build": "npm run build:anchor",
    "test": "anchor test",
    "test:unit": "npx jest app/tests --runInBand",
    "deploy-devnet": "npx ts-node app/scripts/deploy.ts --cluster devnet",
    "deploy-mainnet": "npx ts-node app/scripts/deploy.ts --cluster mainnet",
    "wire-devnet": "npx ts-node app/scripts/wire.ts --cluster devnet",
    "wire-mainnet": "npx ts-node app/scripts/wire.ts --cluster mainnet",
    "dry-run-devnet": "npx ts-node app/scripts/deploy.ts --cluster devnet --dry-run",
    "dry-run-mainnet": "npx ts-node app/scripts/deploy.ts --cluster mainnet --dry-run",
    "clean": "rm -rf target .anchor"
  },
  "dependencies": {
    "@sqds/multisig": "^2.1.3"
  },
  "devDependencies": {
    "@coral-xyz/anchor": "^0.31.1",
    "@layerzerolabs/lz-definitions": "^3.0.86",
    "@layerzerolabs/lz-solana-sdk-v2": "^3.0.136",
    "@layerzerolabs/oft-v2-solana-sdk": "^3.0.136",
    "@metaplex-foundation/mpl-token-metadata": "^3.2.1",
    "@metaplex-foundation/umi": "^0.9.2",
    "@metaplex-foundation/umi-bundle-defaults": "^0.9.2",
    "@metaplex-foundation/umi-web3js-adapters": "^0.9.2",
    "@solana/spl-token": "^0.4.8",
    "@solana/web3.js": "~1.95.8",
    "@types/chai": "^4.3.11",
    "@types/jest": "^29.5.12",
    "@types/node": "~18.18.14",
    "bs58": "^6.0.0",
    "chai": "^4.4.1",
    "dotenv": "^16.4.5",
    "jest": "^29.7.0",
    "mocha": "^10.2.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.4"
  },
  "engines": {
    "node": ">=20"
  }
}
