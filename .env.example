# ─────────────────────────────────────────────────────────────────────────────
# PAYE (PayETH) Solana OFT — Environment Configuration
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Solana deployer / developer keypair ──────────────────────────────────────
# Set ONE of the following (not both):

# Option A: Base-58 private key (as exported from a wallet)
SOLANA_PRIVATE_KEY=

# Option B: Path to a JSON keypair file
SOLANA_KEYPAIR_PATH=~/.config/solana/id.json

# ── Treasury keypair (Koinon wallet — becomes the OFT admin) ─────────────────
# Must be a JSON keypair file.  On mainnet use a Squads multisig key.
TREASURY_KEYPAIR_PATH=

# ── Solana RPC endpoints ──────────────────────────────────────────────────────
# Defaults to public endpoints if not set; provide a premium endpoint for mainnet.
RPC_URL_SOLANA=https://api.mainnet-beta.solana.com
RPC_URL_SOLANA_TESTNET=https://api.devnet.solana.com

# ── OFT Program ID ────────────────────────────────────────────────────────────
# Set after running `anchor keys sync -p paye-oft && anchor build`.
OFT_PROGRAM_ID=

# ── EVM peer addresses ────────────────────────────────────────────────────────
# Testnet (devnet wiring)
EVM_SEPOLIA_PAYE_ADDRESS=0x0000000000000000000000000000000000000000
EVM_LINEA_SEPOLIA_PAYE_ADDRESS=0x0000000000000000000000000000000000000000

# Mainnet (mainnet wiring)
EVM_MAINNET_PAYE_ADDRESS=0x0000000000000000000000000000000000000000
EVM_LINEA_MAINNET_PAYE_ADDRESS=0x0000000000000000000000000000000000000000

# ── Optional: mock endpoint program ID (for local tests) ─────────────────────
MOCK_ENDPOINT_ID=76y77prsiCMvXMjuoZ5VRrhG5qYBrUMYTE5WgHqgjEn6

# ─────────────────────────────────────────────────────────────────────────────
# EVM side (only needed if running mixed EVM+Solana tasks)
# ─────────────────────────────────────────────────────────────────────────────
PRIVATE_KEY=
# or: MNEMONIC="word1 word2 ... word12"
